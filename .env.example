# proxy0 configuration
# Copy this file to `.env` and fill in the credentials for whichever provider(s)
# you want to use. Both blocks are independent — leaving one blank just disables
# that provider.
#
# Setup guides:
#   Vultr  → providers/vultr/SETUP.md
#   Aliyun → providers/aliyun/SETUP.md

# ─── Shared ──────────────────────────────────────────────────────────────────
# Public key written into the server's /root/.ssh/authorized_keys.
# - Unset (this var omitted entirely): auto-detect from ~/.ssh/id_ed25519.pub
#   then ~/.ssh/id_rsa.pub. Recommended default.
# - Set to a literal "ssh-ed25519 AAAA... user@host" line: use that exact key.
# - Set to an empty string: skip key injection entirely (rely on the cloud
#   provider's own key injection / password auth).
# SSH_PUBLIC_KEY=

# Optional overrides (defaults shown):
# INSTANCE_LABEL=proxy0
# XRAY_PORT=443
# XRAY_SNI=www.microsoft.com

# ─── Vultr ───────────────────────────────────────────────────────────────────
# Get from: https://my.vultr.com/settings/#settingsapi
VULTR_API_KEY=
# UUID of the SSH key uploaded at https://my.vultr.com/account/#accountssh
VULTR_SSH_KEY_ID=
# Region slug — list with: python3 main.py vultr regions
VULTR_REGION=icn
# Plan / OS overrides (rarely needed)
# VULTR_PLAN=vc2-1c-1gb
# VULTR_OS_ID=2136

# ─── Aliyun SWAS ─────────────────────────────────────────────────────────────
# RAM user AccessKey from https://ram.console.aliyun.com/users
# (grant the user the AliyunSWASFullAccess policy)
ALIYUN_ACCESS_KEY=
ALIYUN_ACCESS_SECRET=
# Root password set when buying the SWAS instance
ALIYUN_PW=
# ap-southeast-1 (Singapore) or cn-hongkong (Hong Kong)
ALIYUN_REGION=ap-southeast-1
